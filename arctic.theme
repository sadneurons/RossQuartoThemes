{
  "text-color": null,
  "background-color": null,
  "line-number-color": "#5A7090",
  "line-number-background-color": null,
  "text-styles": {
    "Alert":         { "text-color": "#CC0000", "bold": true },
    "Annotation":    { "text-color": "#8A8A94", "italic": true },
    "Attribute":     { "text-color": "#163151" },
    "BaseN":         { "text-color": "#B5600F" },
    "BuiltIn":       { "text-color": "#1A3A60" },
    "Char":          { "text-color": "#2D6A4F" },
    "Comment":       { "text-color": "#8A8A94", "italic": true },
    "CommentVar":    { "text-color": "#8A8A94", "bold": true, "italic": true },
    "Constant":      { "text-color": "#B5600F" },
    "ControlFlow":   { "text-color": "#1A3A60", "bold": true },
    "DataType":      { "text-color": "#1A3A60" },
    "DecVal":        { "text-color": "#B5600F" },
    "Documentation": { "text-color": "#8A8A94", "italic": true },
    "Error":         { "text-color": "#CC0000", "bold": true },
    "Extension":     { "text-color": "#1A3A60" },
    "Float":         { "text-color": "#B5600F" },
    "Function":      { "text-color": "#1A3A60" },
    "Import":        { "text-color": "#1A3A60" },
    "Information":   { "text-color": "#8A8A94", "italic": true },
    "Keyword":       { "text-color": "#1A3A60", "bold": true },
    "Operator":      { "text-color": "#5A7090" },
    "Other":         { "text-color": "#1C1C1C" },
    "Preprocessor":  { "text-color": "#1A3A60" },
    "SpecialChar":   { "text-color": "#1A3A60" },
    "SpecialString": { "text-color": "#2D6A4F" },
    "String":        { "text-color": "#2D6A4F" },
    "Variable":      { "text-color": "#1C1C1C" },
    "VerbatimString":{ "text-color": "#2D6A4F" },
    "Warning":       { "text-color": "#B5600F", "bold": true }
  }
}
